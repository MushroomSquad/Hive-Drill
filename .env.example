# Скопируй в .env и заполни нужные значения
# cp .env.example .env

# --- Директории моделей ---
HF_MODELS_DIR=./hf
LLAMACPP_MODELS_DIR=./llamacpp/data/models

# --- AirLLM настройки ---
AIRLLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
AIRLLM_CTX=8192
AIRLLM_COMPRESSION=4bit

# --- Облачные ключи (для LiteLLM роутера) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- LiteLLM ---
# LITELLM_MASTER_KEY=sk-local-master-key-change-me

# --- Туннель ---
# TUNNEL_PROVIDER=cloudflared   # или ngrok
