# cp .env.example .env
# Никогда не коммить .env

# ─── MCP серверы ────────────────────────────────────────────────────
# GitHub token нужен MCP-серверу для работы с issues/PRs
# Создать: https://github.com/settings/tokens (scope: repo)
GITHUB_TOKEN=ghp_...

# Опциональные MCP-серверы:
# LINEAR_API_KEY=lin_api_...
# DATABASE_URL=postgresql://user:pass@localhost:5432/db

# ─── Локальный LLM ──────────────────────────────────────────────────
# Папки для моделей
HF_MODELS_DIR=./llm/hf
LLAMACPP_MODELS_DIR=./llm/llamacpp/data/models

# Endpoint для Codex local-профиля (TabbyAPI)
LOCAL_LLM_BASE_URL=http://localhost:33931/v1

# AirLLM — только если запускаешь тяжёлые модели (>12GB VRAM)
# AIRLLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
# AIRLLM_CTX=8192
# AIRLLM_COMPRESSION=4bit

# ─── Туннель для Cursor ─────────────────────────────────────────────
# Нужен только если подключаешь Cursor к локальному LLM
# TUNNEL_PROVIDER=cloudflared
